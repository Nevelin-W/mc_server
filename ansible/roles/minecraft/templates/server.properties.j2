# ═══════════════════════════════════════════════
# Minecraft server.properties
# Generated by Ansible – DO NOT EDIT ON SERVER
# Modpack: {{ modpack_name }}
# ═══════════════════════════════════════════════

# ── Network ──────────────────────────────────
server-port={{ server_port }}
query.port={{ query_port }}
enable-query={{ query_enabled | lower }}
server-ip=

# ── RCON ─────────────────────────────────────
enable-rcon={{ rcon_enabled | lower }}
rcon.port={{ rcon_port }}
rcon.password={{ rcon_password }}

# ── Gameplay ─────────────────────────────────
gamemode={{ gamemode }}
difficulty={{ difficulty }}
pvp={{ pvp | lower }}
max-players={{ max_players }}
view-distance={{ view_distance }}
simulation-distance={{ simulation_distance }}
motd={{ motd }}
online-mode={{ online_mode | lower }}
enable-command-block={{ enable_command_block | lower }}

# ── World ────────────────────────────────────
level-name=world
level-type=default
allow-nether=true
spawn-protection=0

# ── Performance ──────────────────────────────
max-tick-time=120000
network-compression-threshold=256
rate-limit=0
sync-chunk-writes=true

{% for key, value in server_properties_extra.items() %}
{{ key }}={{ value }}
{% endfor %}
