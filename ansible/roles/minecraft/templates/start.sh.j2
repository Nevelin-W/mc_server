#!/usr/bin/env bash
# ═══════════════════════════════════════════════
# Minecraft Server Start Script
# Generated by Ansible – DO NOT EDIT MANUALLY
# Modpack: {{ modpack_name }}
# Loader:  {{ modpack_loader }}
# ═══════════════════════════════════════════════
set -euo pipefail

cd "{{ minecraft_home }}/server"

JAVA="{{ java_home | default('/usr/lib/jvm/temurin-' + java_version + '-jdk-amd64/bin/java') }}"

JVM_FLAGS=(
    -Xms{{ jvm_min_memory }}
    -Xmx{{ jvm_max_memory }}
    {{ jvm_extra_flags }}
)

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting Minecraft server..."
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Modpack: {{ modpack_name }}"
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Memory: {{ jvm_min_memory }} - {{ jvm_max_memory }}"

{% if modpack_loader == "forge" %}
# ── Forge ────────────────────────────────────
# Check for modern Forge (1.17+) with run.sh or args file
if [[ -f "{{ minecraft_home }}/server/user_jvm_args.txt" ]]; then
    # Write JVM args to the file Forge expects
    echo "# Generated by Ansible" > "{{ minecraft_home }}/server/user_jvm_args.txt"
    for flag in "${JVM_FLAGS[@]}"; do
        echo "$flag" >> "{{ minecraft_home }}/server/user_jvm_args.txt"
    done
    exec bash "{{ minecraft_home }}/server/run.sh" --nogui
else
    # Legacy Forge – direct java invocation
    FORGE_JAR=$(find . -maxdepth 1 -name 'forge-*.jar' ! -name '*installer*' | sort | tail -1)
    exec "$JAVA" "${JVM_FLAGS[@]}" -jar "$FORGE_JAR" --nogui
fi

{% elif modpack_loader == "fabric" %}
# ── Fabric ───────────────────────────────────
exec "$JAVA" "${JVM_FLAGS[@]}" -jar fabric-server-launch.jar --nogui

{% elif modpack_loader == "neoforge" %}
# ── NeoForge ─────────────────────────────────
if [[ -f "{{ minecraft_home }}/server/user_jvm_args.txt" ]]; then
    echo "# Generated by Ansible" > "{{ minecraft_home }}/server/user_jvm_args.txt"
    for flag in "${JVM_FLAGS[@]}"; do
        echo "$flag" >> "{{ minecraft_home }}/server/user_jvm_args.txt"
    done
    exec bash "{{ minecraft_home }}/server/run.sh" --nogui
else
    NEOFORGE_JAR=$(find . -maxdepth 1 -name 'neoforge-*.jar' ! -name '*installer*' | sort | tail -1)
    exec "$JAVA" "${JVM_FLAGS[@]}" -jar "$NEOFORGE_JAR" --nogui
fi

{% elif modpack_loader == "quilt" %}
# ── Quilt ────────────────────────────────────
exec "$JAVA" "${JVM_FLAGS[@]}" -jar quilt-server-launch.jar --nogui

{% else %}
# ── Vanilla / Unknown ────────────────────────
SERVER_JAR=$(find . -maxdepth 1 -name 'server*.jar' | sort | tail -1)
exec "$JAVA" "${JVM_FLAGS[@]}" -jar "$SERVER_JAR" --nogui
{% endif %}
