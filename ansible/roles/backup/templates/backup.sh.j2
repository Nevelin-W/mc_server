#!/usr/bin/env bash
# ═══════════════════════════════════════════════
# Minecraft World Backup Script
# Generated by Ansible – DO NOT EDIT MANUALLY
#
# Flow:
# 1. Notify players via RCON
# 2. Disable world saving (save-off)
# 3. Force world save (save-all flush)
# 4. Wait for save to complete
# 5. Snapshot world data with restic
# 6. Re-enable world saving (save-on)
# 7. Apply retention policy (prune old backups)
# 8. Report status
# ═══════════════════════════════════════════════
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKUP_HOME="{{ minecraft_home }}/backups"
LOG_FILE="${BACKUP_HOME}/logs/backup.log"
LOCK_FILE="${BACKUP_HOME}/.backup.lock"

MCRCON="{{ minecraft_home }}/tools/mcrcon"
RCON_HOST="127.0.0.1"
RCON_PORT="{{ rcon_port }}"
RCON_PASS="{{ rcon_password }}"

WORLD_DIR="{{ data_volume_mount }}"
SERVER_DIR="{{ minecraft_home }}/server"

# Source restic environment
source "${BACKUP_HOME}/.restic-env"

# ── Helpers ──────────────────────────────────
timestamp() { date '+%Y-%m-%d %H:%M:%S'; }
log() { echo "[$(timestamp)] $*"; }
rcon() { "${MCRCON}" -H "${RCON_HOST}" -P "${RCON_PORT}" -p "${RCON_PASS}" "$@" 2>/dev/null || true; }

# ── Lock (prevent concurrent backups) ────────
cleanup() {
    local exit_code=$?
    rm -f "${LOCK_FILE}"
    # Always re-enable saving
    rcon "save-on"
    if [[ $exit_code -ne 0 ]]; then
        log "ERROR: Backup failed with exit code ${exit_code}"
        rcon "say §c[Backup] Backup FAILED! Check logs."
    fi
}
trap cleanup EXIT

if [[ -f "${LOCK_FILE}" ]]; then
    log "ERROR: Backup already in progress (lock file exists)"
    exit 1
fi
echo $$ > "${LOCK_FILE}"

# ── Pre-backup ───────────────────────────────
log "═══ Starting backup ═══"
BACKUP_START=$(date +%s)

# Check if server is running
if systemctl is-active --quiet minecraft; then
    SERVER_RUNNING=true
    log "Server is running – performing hot backup with save-off"

    rcon "say §e[Backup] Starting world backup... Brief lag possible."
    rcon "save-off"
    sleep 1
    rcon "save-all flush"
    # Wait for save to complete
    sleep 5
else
    SERVER_RUNNING=false
    log "Server is stopped – performing cold backup"
fi

# ── Restic backup ────────────────────────────
log "Taking restic snapshot..."

TAGS="--tag minecraft --tag {{ modpack_name }}"
if [[ "${SERVER_RUNNING}" == "true" ]]; then
    TAGS="${TAGS} --tag hot-backup"
else
    TAGS="${TAGS} --tag cold-backup"
fi

restic backup \
    ${TAGS} \
    --exclude '*.jar' \
    --exclude 'modpack-staging' \
    --exclude 'logs/*.gz' \
    --exclude '.cache' \
    "${WORLD_DIR}" \
    "${SERVER_DIR}/server.properties" \
    "${SERVER_DIR}/ops.json" \
    "${SERVER_DIR}/whitelist.json" \
    "${SERVER_DIR}/banned-ips.json" \
    "${SERVER_DIR}/banned-players.json" \
    "${SERVER_DIR}/.modpack-version" \
    2>&1 | while IFS= read -r line; do log "  restic: ${line}"; done

BACKUP_STATUS=$?

# ── Post-backup ──────────────────────────────
if [[ "${SERVER_RUNNING}" == "true" ]]; then
    rcon "save-on"
    log "World saving re-enabled"
fi

# ── Retention policy (prune) ─────────────────
log "Applying retention policy..."
restic forget \
    --keep-hourly {{ backup_retain_hourly }} \
    --keep-daily {{ backup_retain_daily }} \
    --keep-weekly {{ backup_retain_weekly }} \
    --keep-monthly {{ backup_retain_monthly }} \
    --prune \
    2>&1 | while IFS= read -r line; do log "  prune: ${line}"; done

# ── Report ───────────────────────────────────
BACKUP_END=$(date +%s)
DURATION=$((BACKUP_END - BACKUP_START))

# Get snapshot stats
SNAPSHOT_COUNT=$(restic snapshots --json 2>/dev/null | jq length)
REPO_SIZE=$(restic stats --json 2>/dev/null | jq -r '.total_size' | numfmt --to=iec 2>/dev/null || echo "unknown")

log "═══ Backup complete ═══"
log "  Duration:   ${DURATION}s"
log "  Snapshots:  ${SNAPSHOT_COUNT}"
log "  Repo size:  ${REPO_SIZE}"

if [[ "${SERVER_RUNNING}" == "true" ]]; then
    rcon "say §a[Backup] Backup complete! (${DURATION}s)"
fi

# Write status file for monitoring
cat > "${BACKUP_HOME}/.last-backup-status" <<EOF
timestamp=$(timestamp)
duration_seconds=${DURATION}
status=success
snapshot_count=${SNAPSHOT_COUNT}
repo_size=${REPO_SIZE}
EOF

log "Done."
