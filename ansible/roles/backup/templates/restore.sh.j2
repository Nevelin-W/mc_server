#!/usr/bin/env bash
# ═══════════════════════════════════════════════
# Minecraft World Restore Script
# Generated by Ansible – DO NOT EDIT MANUALLY
#
# Usage:
#   ./restore.sh                  # Restore latest snapshot
#   ./restore.sh <snapshot_id>    # Restore specific snapshot
#   ./restore.sh --list           # List available snapshots
#   ./restore.sh --dry-run <id>   # Preview restore without applying
# ═══════════════════════════════════════════════
set -euo pipefail

BACKUP_HOME="{{ minecraft_home }}/backups"
WORLD_DIR="{{ data_volume_mount }}"
SERVER_DIR="{{ minecraft_home }}/server"
RESTORE_DIR="${BACKUP_HOME}/restore-staging"
MCRCON="{{ minecraft_home }}/tools/mcrcon"
RCON_HOST="127.0.0.1"
RCON_PORT="{{ rcon_port }}"
RCON_PASS="{{ rcon_password }}"

source "${BACKUP_HOME}/.restic-env"

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }
log() { echo "[$(timestamp)] $*"; }
rcon() { "${MCRCON}" -H "${RCON_HOST}" -P "${RCON_PORT}" -p "${RCON_PASS}" "$@" 2>/dev/null || true; }

# ── Parse arguments ──────────────────────────
SNAPSHOT_ID="latest"
DRY_RUN=false

case "${1:-}" in
    --list|-l)
        echo "Available snapshots:"
        echo "──────────────────────────────────────────"
        restic snapshots --compact
        echo ""
        echo "To restore a specific snapshot:"
        echo "  ./restore.sh <snapshot_id>"
        exit 0
        ;;
    --dry-run)
        DRY_RUN=true
        SNAPSHOT_ID="${2:-latest}"
        ;;
    "")
        SNAPSHOT_ID="latest"
        ;;
    *)
        SNAPSHOT_ID="$1"
        ;;
esac

# ── Safety checks ────────────────────────────
log "═══ Starting restore ═══"
log "Snapshot: ${SNAPSHOT_ID}"

# Show what will be restored
log "Snapshot details:"
restic snapshots "${SNAPSHOT_ID}" 2>/dev/null || {
    log "ERROR: Snapshot '${SNAPSHOT_ID}' not found"
    exit 1
}

if [[ "${DRY_RUN}" == "true" ]]; then
    log "DRY RUN – listing files that would be restored:"
    restic ls "${SNAPSHOT_ID}" | head -50
    log "(showing first 50 files)"
    exit 0
fi

# ── Confirm ──────────────────────────────────
echo ""
echo "⚠️  WARNING: This will REPLACE the current world data!"
echo "   Current world data will be backed up to:"
echo "   ${BACKUP_HOME}/local/pre-restore-$(date +%Y%m%d-%H%M%S)"
echo ""
read -p "Type 'RESTORE' to confirm: " CONFIRM
if [[ "${CONFIRM}" != "RESTORE" ]]; then
    log "Restore cancelled."
    exit 0
fi

# ── Stop server ──────────────────────────────
if systemctl is-active --quiet minecraft; then
    log "Stopping Minecraft server..."
    rcon "say §c[Restore] Server shutting down for world restore..."
    sleep 5
    rcon "save-all"
    sleep 3
    rcon "stop"
    sleep 10
    sudo systemctl stop minecraft
    log "Server stopped."
fi

# ── Backup current state (safety net) ────────
PRE_RESTORE_BACKUP="${BACKUP_HOME}/local/pre-restore-$(date +%Y%m%d-%H%M%S)"
log "Backing up current world to ${PRE_RESTORE_BACKUP}..."
mkdir -p "${PRE_RESTORE_BACKUP}"
cp -a "${WORLD_DIR}/" "${PRE_RESTORE_BACKUP}/" 2>/dev/null || true
log "Pre-restore backup complete."

# ── Restore from restic ─────────────────────
log "Restoring from snapshot ${SNAPSHOT_ID}..."

# Clean staging area
rm -rf "${RESTORE_DIR}"
mkdir -p "${RESTORE_DIR}"

# Restore to staging
restic restore "${SNAPSHOT_ID}" --target "${RESTORE_DIR}"

# ── Apply restored files ─────────────────────
log "Applying restored world data..."

# Restore world directory
if [[ -d "${RESTORE_DIR}${WORLD_DIR}" ]]; then
    rm -rf "${WORLD_DIR}/world"
    cp -a "${RESTORE_DIR}${WORLD_DIR}/world" "${WORLD_DIR}/world" 2>/dev/null || true
    log "World data restored."
fi

# Restore server config files
for config_file in server.properties ops.json whitelist.json banned-ips.json banned-players.json; do
    if [[ -f "${RESTORE_DIR}${SERVER_DIR}/${config_file}" ]]; then
        cp -a "${RESTORE_DIR}${SERVER_DIR}/${config_file}" "${SERVER_DIR}/${config_file}"
        log "Restored ${config_file}"
    fi
done

# Fix permissions
chown -R {{ minecraft_user }}:{{ minecraft_group }} "${WORLD_DIR}"
chown -R {{ minecraft_user }}:{{ minecraft_group }} "${SERVER_DIR}"

# Cleanup staging
rm -rf "${RESTORE_DIR}"

# ── Start server ─────────────────────────────
log "Starting Minecraft server..."
sudo systemctl start minecraft
sleep 10

if systemctl is-active --quiet minecraft; then
    log "Server started successfully after restore."
    rcon "say §a[Restore] World restored from backup. Welcome back!"
else
    log "WARNING: Server failed to start after restore!"
    log "Check: journalctl -u minecraft -n 50"
fi

log "═══ Restore complete ═══"
log "Pre-restore backup saved at: ${PRE_RESTORE_BACKUP}"
